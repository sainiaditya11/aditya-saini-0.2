#include <stdio.h>

int main() {
    int arr[5] = {5, 8, 2, 9, 1};
    int num, found = 0;

    printf("Enter number to search: ");
    scanf("%d", &num);

    for(int i = 0; i < 5; i++) {
        if(arr[i] == num) {
            printf("Number found at position %d", i+1);
            found = 1;
            break;
        }
    }

    if(found == 0)
        printf("Number not found");

    return 0;
}
